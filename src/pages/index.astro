---
import Layout from "../layouts/Layout.astro";
import { BentoGrid } from "../components/BentoGrid";
import { Analytics } from "../components/Analytics";
import "../styles/global.css";

// Fetch GitHub data at build time
let avatarUrl = "https://avatars.githubusercontent.com/u/22333076?v=4";
let profileName = "Enzo Lizama Paredes";
let starredRepos: Array<{
  name: string;
  full_name: string;
  description: string | null;
  stargazers_count: number;
  language: string | null;
  html_url: string;
}> = [];

try {
  const [profileRes, starredRes] = await Promise.all([
    fetch("https://api.github.com/users/enzoftware", {
      headers: { Accept: "application/vnd.github.v3+json" },
    }),
    fetch("https://api.github.com/users/enzoftware/starred?per_page=8", {
      headers: { Accept: "application/vnd.github.v3+json" },
    }),
  ]);

  if (profileRes.ok) {
    const profile = await profileRes.json();
    avatarUrl = profile.avatar_url ?? avatarUrl;
    profileName = profile.name ?? profileName;
  }

  if (starredRes.ok) {
    const starred = await starredRes.json();
    starredRepos = starred.map((r: Record<string, unknown>) => ({
      name: r.name as string,
      full_name: r.full_name as string,
      description: r.description as string | null,
      stargazers_count: r.stargazers_count as number,
      language: r.language as string | null,
      html_url: r.html_url as string,
    }));
  }
} catch (_e) {
  // Use defaults on fetch failure
}

const mixpanelToken = import.meta.env.PUBLIC_MIXPANEL_TOKEN ?? "";
---

<Layout>
  <main class="w-full overflow-x-hidden lg:h-dvh lg:overflow-hidden bg-surface">
    <BentoGrid
      client:load
      avatarUrl={avatarUrl}
      name={profileName}
      starredRepos={starredRepos}
    />
  </main>
  <Analytics client:load token={mixpanelToken} />
</Layout>
